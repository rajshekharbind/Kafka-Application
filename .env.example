# Kafka Broker Configuration
KAFKA_BROKERS=localhost:9092

# Server Configuration
PORT=3000
# Node Environment
NODE_ENV=development

# Kafka Consumer Configuration
# Session timeout (ms) - how long the broker will wait before considering consumer dead
KAFKA_SESSION_TIMEOUT=30000

# Heartbeat interval (ms) - how often to send heartbeat to broker
KAFKA_HEARTBEAT_INTERVAL=3000

# Rebalance timeout (ms) - how long to wait for rebalancing to complete
KAFKA_REBALANCE_TIMEOUT=60000

# Auto commit interval (ms)
KAFKA_AUTO_COMMIT_INTERVAL=5000

# Auto commit threshold (bytes)
KAFKA_AUTO_COMMIT_THRESHOLD=100
